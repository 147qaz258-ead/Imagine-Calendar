{
  "name": "career-calendar",
  "version": "0.1.0",
  "private": true,
  "description": "畅选日历 - 职业规划日历平台",
  "scripts": {
    "prepare": "[ \"$NODE_ENV\" != \"production\" ] && husky || true",
    "postinstall": "cd web && npm install",
    "build": "cd web && npm run build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "test": "pnpm -r test",
    "dev": "concurrently \"pnpm --filter web dev\" \"pnpm --filter server start:dev\""
  },
  "devDependencies": {
    "husky": "^9.1.4",
    "lint-staged": "^15.2.8",
    "concurrently": "^8.2.2"
  },
  "lint-staged": {
    "web/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "server/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}