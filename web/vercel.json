{
  "framework": "vite",
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://career-calendar-server.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://career-calendar-server.onrender.com/socket.io/:path*"
    }
  ]
}