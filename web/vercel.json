{
  "buildCommand": "cd ../server && pnpm install && pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "framework": "vite",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://career-calendar-server.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://career-calendar-server.onrender.com/socket.io/:path*"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}