{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://career-calendar-server.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://career-calendar-server.onrender.com/socket.io/:path*"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://career-calendar-server.onrender.com/api/$1"
    },
    {
      "src": "/socket.io/(.*)",
      "dest": "https://career-calendar-server.onrender.com/socket.io/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}